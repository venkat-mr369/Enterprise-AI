# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to Git — it's already in .gitignore.

# --- Local PostgreSQL (for testing this module before touching RDS) ---
# DB_HOST=127.0.0.1
# DB_PORT=5432

# --- Amazon RDS for PostgreSQL ---
# Correct endpoint format for a Postgres RDS instance (port 5432, not 3306):
DB_HOST=mydbinstance.c7tj4example.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=ml_ops_db
DB_USER=ml_user
DB_PASSWORD=REPLACE_WITH_A_GENERATED_SECRET
DB_SSLMODE=require
